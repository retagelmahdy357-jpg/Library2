<Page x:Class="Library2.Signup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Library2"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Signup">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="393*"/>
            <ColumnDefinition Width="7*"/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="/images.jfif"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="280.797"></RowDefinition>
            <RowDefinition Height="27.203"/>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Label FontSize="40" HorizontalAlignment="Left" FontWeight="Bold" Grid.Row="0" Margin="321,0,0,0">Sign Up</Label>
        <StackPanel HorizontalAlignment="Left" Margin="300,63,0,0" Grid.RowSpan="3">
            <Label FontSize="20" FontStyle="Italic" Name="sinname" >Full Name</Label>
            <TextBox Background="AliceBlue" Height="25" Width="200" Name="boxsinname"></TextBox>
            <Label FontSize="20" FontStyle="Italic" Name="sinemail" >Email</Label>
            <TextBox Background="AliceBlue" Height="25" Width="200" Name="boxsinemail" ></TextBox>
            <Label FontSize="20" FontStyle="Italic"  Name="sinpassword" >Password</Label>
            <TextBox Background="AliceBlue" Height="25" Width="200"  Name="boxsinpassword"></TextBox>
            <Label FontSize="20" FontStyle="Italic"  Name="sinconpassword" >Confirm Password</Label>
            <TextBox Background="AliceBlue" Height="25" Width="200" Name="boxsinconpassword"></TextBox>
            <Label FontSize="20" FontStyle="Italic"  Name="sinrole">Role</Label>
            <TextBox Background="AliceBlue" Height="25" Width="200"  Name="boxsinrole"></TextBox>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Left" Margin="336,27,0,0" Grid.RowSpan="2">
            <RadioButton Content="Librarian" x:Name="radio1" />
            <RadioButton Content="Member" x:Name="radio2" />
        </StackPanel>
        <Button Panel.ZIndex="5" Height="35" Width="100" Background="LightGray"  Grid.Row="3" Margin="495,33,191,11" Click="Button_Click" Name="Button">SinUp</Button>
        <Label Grid.Row="3" Margin="619,50,-619,-49" Foreground="#FFE61818" Grid.ColumnSpan="2" >If Allready Have Account?</Label>

    </Grid>
</Page>
